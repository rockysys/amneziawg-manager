{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AmneziaWG Manager",
  "version": "0.1.0",
  "identifier": "com.amneziawg.manager",
  "build": {
    "beforeDevCommand": "node_modules/.bin/vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node_modules/.bin/tsc && node_modules/.bin/vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AmneziaWG Manager",
        "width": 1180,
        "height": 780,
        "minWidth": 900,
        "minHeight": 650,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
